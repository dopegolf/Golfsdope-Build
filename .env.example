# Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# GitHub
GITHUB_TOKEN=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Vercel (conditional)
VERCEL_TOKEN=

# Shopify (when applicable)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_URL=

# Email service (when applicable)
EMAIL_API_KEY=

# Analytics (when applicable)
ANALYTICS_ID=

# Site URLs
SITE_URL=
PREVIEW_URL=
